# Configuración del backend (válido tanto para Docker como local)
# En Docker: REDIS_URL usa host.docker.internal, DATABASE_URL usa postgres
# En local: REDIS_URL usa localhost, DATABASE_URL usa localhost:5433

REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://transcriber:transcriber@localhost:5433/transcriber

# Modelo faster-whisper: tiny, base, small, medium
MODEL_SIZE=small
MODEL_DEVICE=cpu
MODEL_COMPUTE_TYPE=int8

# Token de Hugging Face para pyannote (obligatorio para diarización)
# 1. Crea cuenta en https://huggingface.co
# 2. Acepta términos de uso:
#    https://huggingface.co/pyannote/speaker-diarization-3.1
#    https://huggingface.co/pyannote/segmentation-3.0
# 3. Genera token: https://huggingface.co/settings/tokens
HF_TOKEN=tu_token_aqui
